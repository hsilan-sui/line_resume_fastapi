# Compose
FASTAPI_BIND=127.0.0.1
FASTAPI_PORT=3000

# LINE Bot
LINE_CHANNEL_ID=
LINE_USER_ID=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
RICHMENU_HOME_ID=

# FastAPI -> Node landinfo
NODE_JOB_TOKEN=
LANDINFO_MODE_TTL_SEC=600

# Node worker
WORKER_CONCURRENCY=1
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=1800000
HEADLESS=true

# Landinfo defaults
CITY=H
DISTRICT=13
SECTION=新光段
LANDNO=549
PUBLIC_BASE_URL=http://127.0.0.1:3001

# Cloudflare Worker / R2 result callback used by landinfo worker
CF_WORKER_URL=
WORKER_TOKEN=

# Public tunnel. Prefer Cloudflare Tunnel for Raspberry Pi.
CLOUDFLARED_TOKEN=
NGROK_AUTHTOKEN=

# Optional: random ngrok URL notifier for Discord
DISCORD_WEBHOOK_URL=
NGROK_NOTIFY_WEBHOOK_PATH=/webhook
NGROK_NOTIFY_POLL_SECONDS=30
